      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the JSON response",
              "const response = pm.response.json();",
              "",
              "// Access the token field (usually named 'access_token' or 'token')",
              "const token = response.access_token; ",
              "",
              "// Save the token to your active environment",
              "pm.environment.set(\"sse_token\", token);",
              "",
              "console.log(\"Token saved successfully!\");"
            ],
